# ==============================================================================
# Sherlock — Environmental Variables Template
# Copy this file to '.env' and fill in the values.
# If these variables are not present, Sherlock runs in offline DEMO mode.
# ==============================================================================

# 🌐 Azure AI Foundry / Azure OpenAI Config (Foundry IQ)
# ------------------------------------------------------------------------------
# The API endpoint of your Azure OpenAI service instance.
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# The API key for your Azure OpenAI instance.
AZURE_OPENAI_KEY=your-azure-api-key-here

# The name of your model deployment (e.g., gpt-4o, gpt-4, gpt-35-turbo).
AZURE_OPENAI_DEPLOYMENT=gpt-4o


# 🗄️ Supabase Configuration (Memory Layer)
# ------------------------------------------------------------------------------
# Your Supabase project URL (found in Project Settings -> API).
SUPABASE_URL=https://your-project-id.supabase.co

# The Service Role API key (required to bypass Row Level Security for audit logs).
SUPABASE_SERVICE_KEY=your-supabase-service-role-key-here


# 🐙 GitHub Integration (PR Analysis & Pre-Mortem Warnings)
# ------------------------------------------------------------------------------
# Personal Access Token (PAT) with repo scopes to post comments and open PRs.
GITHUB_TOKEN=ghp_yourpersonalaccesstokenhere

# Secret used to verify webhook payloads from GitHub (X-Hub-Signature-256).
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here


# 💬 Teams Integration (Work IQ Alerting)
# ------------------------------------------------------------------------------
# The Incoming Webhook URL of the Teams channel to post Adaptive Cards.
TEAMS_WEBHOOK_URL=https://m365x123456.webhook.office.com/webhookb2/...


# ⚙️ Watch Mode Configuration
# ------------------------------------------------------------------------------
# How often Sherlock scans your services for anomalies (in minutes).
# Defaults to 15 if not set.
WATCH_MODE_INTERVAL_MIN=15
